# Copy to .env and fill in. Pi reads OPENROUTER_API_KEY; the app the agent
# builds reads all three (see AGENTS.md technical guardrails).
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# one per codespace: z-ai/glm-5.2 | deepseek/deepseek-v4-pro | moonshotai/kimi-k3
LLM_MODEL=z-ai/glm-5.2
